# Free stack — no paid inference API keys. Copy to .env and adjust paths/models.

# --- Ollama (LLM — required) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Must match `ollama list` exactly (e.g. after `ollama pull llama3.2`).
OLLAMA_MODEL=llama3.2:latest
# Optional larger model for the long report (synthesize + revise). Empty = same as OLLAMA_MODEL.
# Examples: llama3.1:8b-instruct-q4_0, qwen2.5:14b-instruct, mistral-small:latest
# OLLAMA_WRITER_MODEL=llama3.1:8b-instruct-q4_0
# Longer reports: num_predict = max output tokens; num_ctx must fit your model.
OLLAMA_NUM_PREDICT=6144
OLLAMA_NUM_CTX=16384
# Optional second model for verify step (cross-model check). Empty = same as OLLAMA_MODEL.
# OLLAMA_VERIFIER_MODEL=llama3.2:3b

# --- Embeddings: huggingface = local sentence-transformers (default) | ollama = same daemon ---
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Chroma (local vector DB) ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=research_corpus

# --- Agent ---
MAX_REFLECTION_ITERATIONS=5
RAG_TOP_K=6
MAX_VERIFICATION_REVISIONS=2
VERIFICATION_ENABLED=true
SEARCH_MAX_RESULTS=5
# Optional Brave Search API key — reliable web results when DuckDuckGo packages fail.
# https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=
SEARCH_DDG_INSTANT_ENABLED=true
# duckduckgo_search (text/news/images); often breaks upstream — default off in code.
# SEARCH_DUCKDUCKGO_PACKAGE_ENABLED=false
SEARCH_SEMANTIC_SCHOLAR_ENABLED=true
SEARCH_SEMANTIC_SCHOLAR_MAX_RESULTS=6
SEARCH_CROSSREF_ENABLED=true
SEARCH_CROSSREF_MAX_RESULTS=5
# Polite pool: use a real contact mailto for Crossref (https://github.com/Crossref/rest-api-doc)
CROSSREF_MAILTO=mailto:you@example.com
SEARCH_ARXIV_ENABLED=true
SEARCH_ARXIV_MAX_RESULTS=6
IMAGE_SEARCH_ENABLED=true
IMAGE_SEARCH_MAX_PER_QUERY=4
GATHER_PARALLELISM=4
URL_FETCH_ENABLED=true
URL_FETCH_PER_SEARCH_STEP=2
EVIDENCE_RERANK_ENABLED=true
# Boost Wikipedia, arXiv, .edu, IETF, etc. when sorting evidence (recommended).
EVIDENCE_AUTHORITY_BONUS_ENABLED=true
# Block Zhihu / Baidu Zhidao / similar CN Q&A mirrors (default). Set true only for Chinese-first research.
SEARCH_ALLOW_CHINESE_QA_MIRRORS=false
# Deprecated (ignored for host blocking); kept for backward-compatible .env files.
SEARCH_PREFER_ENGLISH_SOURCES=true
# Filter dictionary sites and a few brand landers that hijack generic words (e.g. CASE → tractors).
SEARCH_BLOCK_GLOSSARY_SPAM_HOSTS=true
REQUEST_TIMEOUT_S=120

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- FastAPI ---
API_HOST=127.0.0.1
API_PORT=8000
# Return only evidence rows referenced as [n] in the final report (when any exist).
API_EVIDENCE_CITED_ONLY=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
